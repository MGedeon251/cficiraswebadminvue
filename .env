# .env

# Mode de développement
VITE_API_URL=http://localhost:3000

# Clé publique (ex: pour une API tierce comme Stripe)
VITE_PUBLIC_KEY=cficiras2026

# Activation des logs de debug
VITE_DEBUG=true

# Nom de l'application
VITE_APP_NAME=MonApplicationVue

# Base URL (utile si l'app est déployée dans un sous-dossier)
VITE_BASE_URL=/

# Exemple de variable privée (non accessible dans le frontend, juste pour les outils de build)
NODE_ENV=development
